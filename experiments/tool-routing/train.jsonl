{"prompt": "Check for vulnerabilities", "completion": "govulncheck ./..."}
{"prompt": "Update dependencies", "completion": "go get -u ./... && go mod tidy"}
{"prompt": "Show the latest release", "completion": "gh release list --limit=1"}
