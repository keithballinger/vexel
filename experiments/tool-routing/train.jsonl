{"prompt": "What's the current version?", "completion": "cat VERSION"}
{"prompt": "Check disk usage on the cluster", "completion": "kubectl exec -n production deploy/api-server -- df -h /data"}
{"prompt": "SSH into the bastion", "completion": "ssh bastion.internal.acme.dev"}
